{
  "name": "nerds-mdx-blog",
  "version": "0.1.0",
  "description": "Drop-in MDX blog for Next.js. Install, init, write posts.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nerds-mdx-blog": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css/fallback.css": "./src/css/fallback.css",
    "./components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./mdx": {
      "import": "./dist/mdx/index.js",
      "types": "./dist/mdx/index.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins/index.js",
      "types": "./dist/plugins/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/css",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^3.20.0",
    "unist-util-visit": "^5.1.0"
  },
  "peerDependencies": {
    "@tailwindcss/typography": ">=0.5",
    "mermaid": ">=10",
    "next": ">=14",
    "next-mdx-remote": ">=5",
    "react": ">=18",
    "react-dom": ">=18",
    "react-tweet": ">=3",
    "tailwindcss": ">=3"
  },
  "peerDependenciesMeta": {
    "mermaid": {
      "optional": true
    },
    "react-tweet": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "mdast-util-mdx-jsx": "^3.2.0",
    "mermaid": "^11.14.0",
    "next": "^15.0.0",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-tweet": "^3.3.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "unified": "^11.0.5",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "nextjs",
    "mdx",
    "blog",
    "react",
    "tailwind",
    "seo",
    "rss"
  ]
}
